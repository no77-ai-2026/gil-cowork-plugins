<!doctype html>
<html lang="ko">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{title}}</title>
  <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin>
  <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/static/pretendard.css">
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&display=swap">
  <style>
    /* ============================================================
       CSS 변수 계약 (design-tokens.md 단일 진실 준수)
       html-report v2.2.0 — status 모드
    ============================================================ */
    :root {
      /* 팔레트 */
      --ivory:  #FAF9F5;
      --paper:  #FFFFFF;
      --slate:  #141413;
      --clay:   #D97757;
      --clay-d: #B85C3E;
      --oat:    #E3DACC;
      --olive:  #788C5D;

      /* 그레이 스케일 */
      --g100: #F0EEE6;
      --g300: #D1CFC5;
      --g500: #87867F;
      --g700: #3D3D3A;

      /* 폰트 — status 모드: Pretendard + JetBrains Mono */
      --sans:  "Pretendard", system-ui, -apple-system, "Segoe UI", sans-serif;
      --serif: "Pretendard", ui-serif, Georgia, serif;
      --mono:  "JetBrains Mono", ui-monospace, "SF Mono", Menlo, Consolas, monospace;

      /* 레이아웃 */
      --max-width:    860px;
      --radius-panel: 12px;
      --radius-row:   8px;
      --border:       1.5px solid var(--g300);
    }

    /* ============================================================
       기반 스타일
    ============================================================ */
    * { box-sizing: border-box; }

    body {
      margin: 0;
      padding: 56px 24px 120px;
      background: var(--ivory);
      color: var(--slate);
      font-family: var(--sans);
      font-size: 15px;
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
    }

    .page {
      max-width: var(--max-width);
      margin: 0 auto;
    }

    /* ============================================================
       헤더
    ============================================================ */
    header {
      margin-bottom: 40px;
    }

    .header-top {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 12px;
      margin-bottom: 8px;
    }

    .eyebrow {
      font-family: var(--mono);
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--g500);
      margin: 0 0 10px;
    }

    h1 {
      font-family: var(--serif);
      font-weight: 600;
      font-size: 36px;
      letter-spacing: -0.01em;
      margin: 0;
      color: var(--slate);
      line-height: 1.2;
    }

    .auto-pill {
      font-family: var(--mono);
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--g500);
      background: var(--g100);
      border: var(--border);
      border-radius: 999px;
      padding: 5px 11px;
      white-space: nowrap;
      flex-shrink: 0;
    }

    .date-range {
      color: var(--g500);
      font-size: 14px;
      margin-top: 6px;
    }

    .date-range .repo {
      font-family: var(--mono);
      font-size: 13px;
      color: var(--g700);
    }

    /* ============================================================
       섹션 공통
    ============================================================ */
    section {
      margin-bottom: 52px;
    }

    h2 {
      font-family: var(--serif);
      font-weight: 600;
      font-size: 22px;
      letter-spacing: -0.01em;
      margin: 0 0 6px;
      color: var(--slate);
    }

    hr.rule {
      border: none;
      border-top: 1px solid var(--g300);
      margin: 0 0 22px;
    }

    /* ============================================================
       메트릭 카드 그리드
    ============================================================ */
    .metrics-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 14px;
    }

    @media (max-width: 720px) {
      .metrics-grid { grid-template-columns: repeat(2, 1fr); }
    }

    @media (max-width: 400px) {
      .metrics-grid { grid-template-columns: 1fr; }
    }

    .stat-card {
      background: var(--paper);
      border: var(--border);
      border-radius: var(--radius-panel);
      padding: 20px 22px 18px;
    }

    .stat-card.warn {
      border-left: 4px solid var(--clay);
      padding-left: 19px;
    }

    .stat-num {
      font-family: var(--serif);
      font-size: 42px;
      font-weight: 600;
      line-height: 1;
      color: var(--slate);
      margin-bottom: 8px;
    }

    .stat-label {
      font-family: var(--sans);
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--g500);
    }

    .stat-delta {
      font-family: var(--mono);
      font-size: 11px;
      margin-top: 6px;
    }

    .stat-delta.up   { color: var(--olive); }
    .stat-delta.down { color: var(--clay-d); }
    .stat-delta.flat { color: var(--g500); }

    /* ============================================================
       하이라이트 목록
    ============================================================ */
    .highlights {
      list-style: none;
      margin: 0;
      padding: 0;
    }

    .highlights li {
      position: relative;
      padding: 0 0 14px 26px;
      font-size: 15px;
      color: var(--g700);
    }

    .highlights li::before {
      content: "";
      position: absolute;
      left: 6px;
      top: 8px;
      width: 7px;
      height: 7px;
      border-radius: 2px;
      background: var(--clay);
    }

    .highlights li strong {
      color: var(--slate);
      font-weight: 600;
    }

    /* ============================================================
       완료 테이블 (shipped)
    ============================================================ */
    table.shipped {
      width: 100%;
      border-collapse: separate;
      border-spacing: 0;
      background: var(--paper);
      border: var(--border);
      border-radius: var(--radius-panel);
      overflow: hidden;
    }

    table.shipped thead th {
      text-align: left;
      font-family: var(--sans);
      font-size: 11px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--g500);
      background: var(--g100);
      padding: 12px 16px;
      border-bottom: 1px solid var(--g300);
    }

    table.shipped tbody td {
      padding: 13px 16px;
      border-bottom: 1px solid var(--g100);
      font-size: 14px;
      vertical-align: middle;
      color: var(--slate);
    }

    table.shipped tbody tr:last-child td {
      border-bottom: none;
    }

    table.shipped tbody tr:hover {
      background: var(--ivory);
    }

    .item-link {
      font-family: var(--mono);
      font-size: 13px;
      color: var(--clay);
      text-decoration: none;
      border-bottom: 1px dotted transparent;
    }

    .item-link:hover {
      border-bottom-color: var(--clay);
    }

    .author {
      color: var(--g700);
      font-size: 13px;
    }

    .risk {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      font-size: 12px;
      color: var(--g500);
    }

    .risk-dot {
      width: 9px;
      height: 9px;
      border-radius: 50%;
      flex-shrink: 0;
    }

    .risk-dot.low  { background: var(--olive); }
    .risk-dot.med  { background: var(--clay); }
    .risk-dot.high { background: var(--clay-d); }

    /* ============================================================
       Velocity 차트
    ============================================================ */
    .chart-panel {
      background: var(--paper);
      border: var(--border);
      border-radius: var(--radius-panel);
      padding: 24px 28px 18px;
    }

    .chart-panel svg {
      display: block;
      width: 100%;
      height: auto;
    }

    .chart-caption {
      font-size: 12px;
      color: var(--g500);
      margin-top: 12px;
      font-family: var(--sans);
    }

    /* ============================================================
       Carryover
    ============================================================ */
    .carryover {
      background: var(--oat);
      border-radius: var(--radius-panel);
      padding: 20px 22px;
    }

    .carry-group {
      margin-bottom: 18px;
    }

    .carry-group:last-child {
      margin-bottom: 0;
    }

    .carry-group-title {
      font-family: var(--mono);
      font-size: 10px;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--g500);
      margin: 0 0 8px;
    }

    .carry-item {
      display: flex;
      align-items: baseline;
      gap: 14px;
      padding: 8px 0;
    }

    .carry-item + .carry-item {
      border-top: 1px solid rgba(20, 20, 19, 0.08);
    }

    .carry-tag {
      font-family: var(--mono);
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--g700);
      background: var(--ivory);
      border-radius: 4px;
      padding: 3px 7px;
      flex-shrink: 0;
    }

    .carry-body {
      font-size: 14px;
      color: var(--g700);
    }

    .carry-body .who {
      color: var(--g500);
      font-size: 12px;
    }

    /* ============================================================
       푸터
    ============================================================ */
    footer {
      margin-top: 64px;
      padding-top: 20px;
      border-top: 1px solid var(--g300);
      font-family: var(--mono);
      font-size: 12px;
      color: var(--g500);
    }

    /* ============================================================
       인쇄 스타일
    ============================================================ */
    @media print {
      body {
        background: white;
        color: black;
        padding: 0;
        font-size: 12pt;
      }

      .page {
        max-width: none;
      }

      a[href]::after {
        content: " (" attr(href) ")";
        font-size: 10pt;
        color: #555;
      }

      h1, h2, h3 {
        page-break-after: avoid;
      }

      table, figure, .chart-panel {
        page-break-inside: avoid;
      }

      .no-print {
        display: none !important;
      }

      * {
        -webkit-print-color-adjust: exact;
        print-color-adjust: exact;
      }
    }
  </style>
</head>
<body>
  <div class="page">

    <!-- ========================================================
         헤더
    ======================================================== -->
    <header>
      <p class="eyebrow">현황 보고 &middot; {{date_range}}</p>
      <div class="header-top">
        <h1>{{title}}</h1>
        <span class="auto-pill">자동 생성</span>
      </div>
      <div class="date-range">
        {{date_range}} &nbsp;&middot;&nbsp;
        <span class="repo">{{repository}}</span>
      </div>
    </header>

    <!-- ========================================================
         메트릭 카드
         metrics: [{label, value, delta, delta_type, warn}]
         delta_type: "up" | "down" | "flat"
         warn: true → clay 왼쪽 테두리
    ======================================================== -->
    <section aria-label="핵심 지표">
      <div class="metrics-grid">
        {{#metrics}}
        <div class="stat-card{{#warn}} warn{{/warn}}">
          <div class="stat-num">{{value}}</div>
          <div class="stat-label">{{label}}</div>
          {{#delta}}<div class="stat-delta {{delta_type}}">{{delta}}</div>{{/delta}}
        </div>
        {{/metrics}}
      </div>
    </section>

    <!-- ========================================================
         하이라이트
         highlights: [string]  (HTML 허용)
    ======================================================== -->
    <section aria-label="주요 현황">
      <h2>하이라이트</h2>
      <hr class="rule">
      <ul class="highlights">
        {{#highlights}}
        <li>{{{.}}}</li>
        {{/highlights}}
      </ul>
    </section>

    <!-- ========================================================
         완료 항목 테이블
         shipped_table: [{id, title, author, risk}]
         risk: "low" | "med" | "high"
         risk_label: "낮음" | "보통" | "높음"
    ======================================================== -->
    <section aria-label="완료 항목">
      <h2>완료</h2>
      <hr class="rule">
      <table class="shipped">
        <thead>
          <tr>
            <th style="width: 90px;">항목</th>
            <th>제목</th>
            <th style="width: 140px;">담당자</th>
            <th style="width: 100px;">위험도</th>
          </tr>
        </thead>
        <tbody>
          {{#shipped_table}}
          <tr>
            <td><a class="item-link" href="{{link}}">#{{id}}</a></td>
            <td>{{title}}</td>
            <td class="author">{{author}}</td>
            <td>
              <span class="risk">
                <span class="risk-dot {{risk}}"></span>{{risk_label}}
              </span>
            </td>
          </tr>
          {{/shipped_table}}
        </tbody>
      </table>
    </section>

    <!-- ========================================================
         Velocity SVG 막대 차트
         velocity_chart: {
           labels: ["월","화","수","목","금","토","일"],
           values: [2, 3, 1, 4, 2, 1, 1],
           unit: "완료",
           caption: "설명 텍스트"
         }
         렌더링 규칙:
         - viewBox: 640×180
         - 막대 너비: 56, 간격: 24, 시작 x: 64
         - baseline y: 140, 단위 높이: 40px (최댓값 기준 스케일)
         - 최댓값 막대: fill #D97757 (--clay), 나머지: fill #E3DACC (--oat)
    ======================================================== -->
    <section aria-label="속도 차트">
      <h2>작업 속도</h2>
      <hr class="rule">
      <div class="chart-panel">
        <svg viewBox="0 0 640 180" role="img" aria-label="{{velocity_chart.caption}}">
          <!-- 그리드라인 -->
          <line x1="48" y1="20"  x2="620" y2="20"  stroke="#F0EEE6" stroke-width="1"/>
          <line x1="48" y1="60"  x2="620" y2="60"  stroke="#F0EEE6" stroke-width="1"/>
          <line x1="48" y1="100" x2="620" y2="100" stroke="#F0EEE6" stroke-width="1"/>
          <line x1="48" y1="140" x2="620" y2="140" stroke="#D1CFC5" stroke-width="1.5"/>

          <!-- y축 레이블 -->
          <text x="40" y="144" text-anchor="end" font-family="system-ui" font-size="11" fill="#87867F">0</text>
          <text x="40" y="104" text-anchor="end" font-family="system-ui" font-size="11" fill="#87867F">{{velocity_chart.y1}}</text>
          <text x="40" y="64"  text-anchor="end" font-family="system-ui" font-size="11" fill="#87867F">{{velocity_chart.y2}}</text>
          <text x="40" y="24"  text-anchor="end" font-family="system-ui" font-size="11" fill="#87867F">{{velocity_chart.y3}}</text>

          <!-- 막대 (7개, 위치 계산: x = 64 + idx*80)
               값 → 높이 = (value/max_value)*140
               y = 140 - height
               최댓값 막대는 fill="#D97757", 나머지는 fill="#E3DACC" -->
          {{#velocity_chart.bars}}
          <rect x="{{x}}" y="{{y}}" width="56" height="{{height}}" rx="6" fill="{{fill}}"/>
          <text x="{{cx}}" y="{{label_y}}" text-anchor="middle" font-family="system-ui" font-size="11" fill="{{text_fill}}" {{#is_peak}}font-weight="600"{{/is_peak}}>{{value}}</text>
          <text x="{{cx}}" y="158" text-anchor="middle" font-family="system-ui" font-size="11" fill="#87867F">{{label}}</text>
          {{/velocity_chart.bars}}
        </svg>
        <div class="chart-caption">{{velocity_chart.caption}}</div>
      </div>
    </section>

    <!-- ========================================================
         Carryover
         carryover: {
           in_review: [{text, who}],
           blocked:   [{text, who}],
           slipped:   [{text, who}]
         }
    ======================================================== -->
    <section aria-label="이월 항목">
      <h2>이월</h2>
      <hr class="rule">
      <div class="carryover">
        {{#carryover.in_review.length}}
        <div class="carry-group">
          <p class="carry-group-title">검토 중</p>
          {{#carryover.in_review}}
          <div class="carry-item">
            <span class="carry-tag">검토 중</span>
            <div class="carry-body">
              {{text}}
              {{#who}}<span class="who">&middot; {{who}}</span>{{/who}}
            </div>
          </div>
          {{/carryover.in_review}}
        </div>
        {{/carryover.in_review.length}}

        {{#carryover.blocked.length}}
        <div class="carry-group">
          <p class="carry-group-title">블로킹</p>
          {{#carryover.blocked}}
          <div class="carry-item">
            <span class="carry-tag">블로킹</span>
            <div class="carry-body">
              {{text}}
              {{#who}}<span class="who">&middot; {{who}}</span>{{/who}}
            </div>
          </div>
          {{/carryover.blocked}}
        </div>
        {{/carryover.blocked.length}}

        {{#carryover.slipped.length}}
        <div class="carry-group">
          <p class="carry-group-title">이월</p>
          {{#carryover.slipped}}
          <div class="carry-item">
            <span class="carry-tag">이월</span>
            <div class="carry-body">
              {{text}}
              {{#who}}<span class="who">&middot; {{who}}</span>{{/who}}
            </div>
          </div>
          {{/carryover.slipped}}
        </div>
        {{/carryover.slipped.length}}
      </div>
    </section>

    <footer>
      출처: {{footer_sources}} &nbsp;&mdash;&nbsp; 생성일: {{generated_at}}
    </footer>

  </div>
</body>
</html>
