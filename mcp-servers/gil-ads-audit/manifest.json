      "description_en": "Andromeda & platform changes 4-check audit (M-AN1/AT1/IA1/TH1)",
      "checks": ["M-AN1", "M-AT1", "M-IA1", "M-TH1"],
      "check_count": 4,
      "implemented": true
    },
    {
      "name": "calculate_health_score",
      "req": "REQ-AUDIT-MCP-012",
      "description_ko": "가중치 스코어링 공식 산출 — S_total + A-F 등급 (claude-ads v1.5.1 공식 인용)",
      "description_en": "Weighted health score calculation — S_total + A-F grade (claude-ads v1.5.1 formula)",
      "formula": "S_total = Σ(C_pass × W_sev × W_cat) / Σ(C_total × W_sev × W_cat) × 100",
      "severity_multipliers": {
        "Critical": 5.0,
        "High": 3.0,
        "Medium": 1.5,
        "Low": 0.5
      },
      "category_weights": {
        "pixel_capi": 0.30,
        "creative": 0.30,
        "account_structure": 0.20,
        "audience": 0.20
      },
      "grade_thresholds": {
        "A": 90,
        "B": 75,
        "C": 60,
        "D": 40,
        "F": 0
      },
      "implemented": true
    },
    {
      "name": "generate_quick_wins",
      "req": "REQ-AUDIT-MCP-013",
      "description_ko": "Quick Win 항목 리스트 — Critical/High + 15분 기준값 필터 + 한국어 조치 가이드",
      "description_en": "Quick wins — Critical/High severity + 15-min threshold filter + Korean remediation guide",
