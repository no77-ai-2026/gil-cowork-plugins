  "version": "0.2.0",
  "platform": "Meta",
  "cowork_version": "2.5.0",

  "tools": [
    {
      "name": "audit_meta_account",
      "req": "REQ-AUDIT-MCP-006",
      "description_ko": "Meta 광고 계정 전체 audit — 4 카테고리 합산 health score + A-F 등급",
      "description_en": "Full Meta account audit — 4-category weighted health score + A-F grade",
      "input": {
        "scope": "account | campaign | adset",
        "time_range": "string (예: '2026-03 ~ 2026-04')",
        "xlsx_path": "string | null (Layer 1 MCP 비활성 시 fallback)"
      },
      "output": {
        "total_score": "float 0-100",
        "grade": "A | B | C | D | F",
        "grade_kr_label": "string (한국 시장 표현)",
        "category_scores": "object {pixel_capi, creative, account_structure, audience}",
        "pixel_capi_result": "object",
        "creative_result": "object (NOT_IMPLEMENTED_V1)",
        "account_structure_result": "object (NOT_IMPLEMENTED_V1)",
        "audience_result": "object (NOT_IMPLEMENTED_V1)"
      },
      "implemented": true,
      "categories_active": ["pixel_capi"],
      "categories_stub": ["creative", "account_structure", "audience"]
    },
    {
      "name": "audit_pixel_capi",
      "req": "REQ-AUDIT-MCP-007",
      "description_ko": "Pixel/CAPI Health 10개 check (M01-M10) — EMQ tiered targets + dedup rate",
      "description_en": "Pixel/CAPI Health 10-check audit (M01-M10) — EMQ tiered targets + dedup rate",
      "checks": ["M01", "M02", "M03", "M04", "M05", "M06", "M07", "M08", "M09", "M10"],
      "check_count": 10,
      "emq_thresholds": {
        "Purchase": 8.5,
        "AddToCart": 6.5,
        "PageView": 5.5
      },
      "dedup_rate_threshold": 0.9,
      "input": {
        "pixel_id": "string",
        "event_log": "list[object] | null",
        "xlsx_path": "string | null",
        "emq_scores": "object | null",
        "capi_enabled": "bool | null",
        "has_em_hash": "bool | null",
        "has_ph_hash": "bool | null",
        "has_external_id": "bool | null"
      },
      "output": {
        "checks": "list[{check_id, status, severity, description, expected_impact, remediation_option}]",
        "category_score": "float 0-100",
        "pass_count": "int",
        "warning_count": "int",
        "fail_count": "int",
        "na_count": "int",
        "emq_summary": "object",
        "dedup_rate": "float | null"
      },
      "implemented": true
    },
    {
      "name": "audit_creative_diversity",
      "req": "REQ-AUDIT-MCP-008",
