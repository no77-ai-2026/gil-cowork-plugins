        "severity": ["Critical", "High"],
        "threshold_minutes": 15,
        "threshold_note": "claude-ads 원전 분류 기준값 (시간 예측 아님, REQ-AUDIT-MCP-022 예외)"
      },
      "implemented": true
    },
